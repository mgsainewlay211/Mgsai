# ========== HWID CHECK - START ==========
def get_hwid():
    """ ဖုန်းတစ်ခုချင်းစီအတွက် မတူညီတဲ့ သီးသန့် HWID ထုတ်ပေးမည့် Function """
    try:
        # Termux သို့မဟုတ် Android phone ရဲ့ device အချက်အလက်အချို့ကို ယူပါတယ်
        model = subprocess.check_output("getprop ro.product.model", shell=True).decode().strip()
        brand = subprocess.check_output("getprop ro.product.brand", shell=True).decode().strip()
        # ပိုပြီး စိတ်ချရအောင် ပေါင်းစပ်ပြီး SHA-256 ရိုက်ပါတယ်
        raw_id = f"{brand}-{model}-unique-salt-123"
        hwid = hashlib.sha256(raw_id.encode()).hexdigest()[:16] # စာလုံး ၁၆ လုံးပဲ ဖြတ်ယူမယ်
        return hwid.upper()
    except Exception:
        # ကွန်ပျူတာ သို့မဟုတ် တခြားနေရာမှာ စမ်းရင် ပုံသေတစ်ခု ထွက်အောင် လုပ်ထားခြင်း
        return "DEFAULT_HWID_999"

def check_key():
    user_hwid = get_hwid()
    print(f"သင့်ဖုန်း၏ HWID: {user_hwid}")
    
    # GitHub URL မှ ဒေတာ ဖတ်ခြင်း
    url = "https://raw.githubusercontent.com/mgsainewlay211/Mgsai/refs/heads/main/key.txt"
    try:
        response = requests.get(url)
        if response.status_code == 200:
            # GitHub ထဲမှာ သိမ်းထားမယ့် ပုံစံက "KEY:HWID" သို့မဟုတ် HWID သီးသန့် ဖြစ်ရပါမယ်
            allowed_keys = response.text.splitlines()
            
            # ဝင်လာတဲ့ HWID က GitHub ထဲမှာ ရှိမရှိ စစ်ဆေးခြင်း
            if user_hwid in allowed_keys:
                print("✅ Access Granted! အသုံးပြုခွင့် ရရှိပါပြီ။")
                return True
            else:
                print("❌ Access Denied! သင့် HWID သည် စာရင်းထဲတွင် မရှိပါ။")
                return False
        else:
            print("🌐 GitHub သို့ ချိတ်ဆက်၍ မရပါ။")
            return False
    except Exception as e:
        print(f"⚠️ Error ဖြစ်ပွားခဲ့သည်: {e}")
        return False

# Script စတင်တာနဲ့ HWID စစ်ဆေးမယ်
if not check_key():
    sys.exit(1)  # ခွင့်မပြုရင် ထွက်သွားမယ်
# ========== HWID CHECK - END ==========

